{
  "name": "yellbot-power",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "General-purpose, self-hostable Discord bot template (Sapphire + discord.js)",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "format": "prettier --write \"src/**/*.ts\" \"README.md\"",
    "commands:register": "tsx src/scripts/registerCommands.ts"
  },
  "dependencies": {
    "@sapphire/decorators": "^6.2.0",
    "@sapphire/framework": "^5.5.0",
    "@sapphire/plugin-logger": "^4.1.0",
    "better-sqlite3": "^12.6.2",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sapphire/prettier-config": "^2.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "prettier": "@sapphire/prettier-config"
}
